rules_version = '2';

// Open by design: this is an assignment/demo backend with no auth, so every
// client shares one unauthenticated `sportRecords` collection. Rules are
// wide open rather than accidentally missing.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
